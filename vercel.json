{
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/((css|js|assets|pages|images)/.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/(?!api/|css/|js/|assets/|pages/|images/).*",
      "dest": "/public/pages/login.html"
    },
    {
      "src": "/",
      "dest": "/public/pages/login.html"
    }
  ]
}
